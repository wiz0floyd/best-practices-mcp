{
  "name": "best-practices-mcp",
  "version": "0.1.0",
  "description": "MCP server for searching mynow.servicenow.com (ServiceNow Global Search) across content types",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "best-practices-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "probe": "tsx scripts/probe.ts",
    "probe-content-fields": "tsx scripts/probe-content-fields.ts",
    "probe-content-page": "tsx scripts/probe-content-page.ts",
    "probe-headed-login": "tsx scripts/probe-headed-login.ts",
    "login": "tsx scripts/login.ts",
    "probe-bpl-download": "tsx scripts/probe-bpl-download.ts",
    "probe-bpl-token-capture": "tsx scripts/probe-bpl-token-capture.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "playwright": "^1.61.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
