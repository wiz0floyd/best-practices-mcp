# ServiceNow instance to search
SN_INSTANCE_URL=https://mynow.servicenow.com

# One of: bearer | basic | cookie
SN_AUTH_MODE=bearer

# --- SN_AUTH_MODE=bearer ---
# An OAuth access token or personal API token for mynow.servicenow.com
SN_BEARER_TOKEN=

# --- SN_AUTH_MODE=basic ---
SN_USERNAME=
SN_PASSWORD=

# --- SN_AUTH_MODE=cookie (SSO fallback, most fragile) ---
# The Cookie header value from an authenticated browser session against
# mynow.servicenow.com (e.g. "glide_user_route=...; JSESSIONID=...").
# Expires when the session does; breaks on MFA/SSO re-prompts.
SN_SESSION_COOKIE=
# Optional: ServiceNow's X-UserToken CSRF header, only add this if the probe
# shows 401/403 under cookie mode when bearer/basic don't hit the same issue.
SN_USER_TOKEN=
