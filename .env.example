# mynow.servicenow.com is public and requires no authentication. This var is optional —
# only set it if you need to point the server at a different ServiceNow instance that
# exposes the same anonymous search flow (GET a page for a guest session, POST
# /api/now/v1/batch). See src/servicenow/search.ts and scripts/probe.ts.
SN_INSTANCE_URL=https://mynow.servicenow.com

# The two vars below are optional and only matter for servicenow_download_document — search
# itself still needs no auth. They control where `npm run login`'s captured session (a real
# credential — never commit it) and downloaded files are stored. See src/servicenow/login.ts
# and src/servicenow/download.ts.
# SN_AUTH_STATE_PATH=.auth/servicenow-storage-state.json
# SN_DOWNLOAD_DIR=.auth/downloads
