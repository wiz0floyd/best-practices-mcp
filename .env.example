# mynow.servicenow.com is public and requires no authentication. This var is optional —
# only set it if you need to point the server at a different ServiceNow instance that
# exposes the same anonymous search flow (GET a page for a guest session, POST
# /api/now/v1/batch). See src/servicenow/search.ts and scripts/probe.ts.
SN_INSTANCE_URL=https://mynow.servicenow.com
